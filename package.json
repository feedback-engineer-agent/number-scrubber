{
  "name": "number-scrubber",
  "version": "1.0.1",
  "description": "An LSP server that lets you use the mouse drag action to update numbers in your text editor. Plugins available for neovim and vscode. Works great alongside websocket-text-relay.",
  "bin": {
    "number-scrubber": "./start.js"
  },
  "scripts": {
    "format": "biome check --write",
    "lint": "biome check",
    "test": "npm run lint"
  },
  "type": "module",
  "main": "./src/NumberScrubber.js",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/niels4/number-scrubber.git"
  },
  "keywords": [
    "JSON-RPC",
    "LSP",
    "server",
    "neovim",
    "vscode",
    "mouse",
    "number",
    "scrubber"
  ],
  "author": "Niels Nielsen",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/niels4/number-scrubber/issues"
  },
  "homepage": "https://github.com/niels4/number-scrubber",
  "dependencies": {
    "json-rpc-interface": "^1.0.1",
    "robotjs": "^0.7.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1"
  }
}
